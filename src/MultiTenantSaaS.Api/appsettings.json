{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5433;Database=multitenant_saas;Username=postgres;Password=postgres",
    "Redis": "localhost:6379"
  },
  "Jwt": {
    "Issuer": "MultiTenantSaaS",
    "Audience": "MultiTenantSaaS",
    "SecretKey": "dev-secret-key-change-in-production-min-32-chars!",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "RateLimit": {
    "LoginPermitLimit": 10,
    "LoginWindowSeconds": 60,
    "RefreshPermitLimit": 20,
    "RefreshWindowSeconds": 60
  },
  "Identity": {
    "MaxFailedAttempts": 5,
    "LockoutMinutes": 15
  }
}
